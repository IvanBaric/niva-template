{
    "name": "ivanbaric/niva-template",
    "description": "Reusable public website template, navigation and Pages section editor catalog.",
    "type": "library",
    "license": "MIT",
    "require": {
        "php": "^8.3",
        "illuminate/database": "^13.0",
        "illuminate/support": "^13.0",
        "illuminate/view": "^13.0",
        "ivanbaric/blog": "@dev",
        "ivanbaric/corexis": "^0.1 || ^1.0 || dev-main as 1.0.0",
        "ivanbaric/gallery": "@dev",
        "ivanbaric/pages": "@dev",
        "ivanbaric/taxonomy": "@dev",
        "ivanbaric/template-engine": "@dev",
        "livewire/flux": "^2.0",
        "livewire/livewire": "^4.0"
    },
    "require-dev": {
        "orchestra/testbench": "^11.0",
        "phpunit/phpunit": "^12.0"
    },
    "autoload": {
        "psr-4": {
            "IvanBaric\\NivaTemplate\\": "src/"
        }
    },
    "autoload-dev": {
        "psr-4": {
            "IvanBaric\\NivaTemplate\\Tests\\": "tests/"
        }
    },
    "extra": {
        "laravel": {
            "providers": [
                "IvanBaric\\NivaTemplate\\NivaTemplateServiceProvider"
            ]
        }
    },
    "minimum-stability": "stable",
    "prefer-stable": true
}
